      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 15},
      "targets": [{
        "expr": "rate(node_network_receive_packets_total{device=\"ens19\"}[5m])",
        "legendFormat": "{{instance}}",
        "refId": "A"
      }],
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
